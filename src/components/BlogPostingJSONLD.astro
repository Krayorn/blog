---
const { title, description, pubDate, updateDate, tags } = Astro.props;

const toIsoDate = (date: Date | string) =>
  date instanceof Date ? date.toISOString().substring(0, 10) : date.toString().substring(0, 10);

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "keywords": tags,
  "author": {
    "@type": "Person",
    "name": "Nathael Arki",
    "url": "https://www.krayorn.com"
  },
  "datePublished": toIsoDate(pubDate),
  ...(updateDate && { "dateModified": toIsoDate(updateDate) }),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />