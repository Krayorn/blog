---
import MissionCard from '../../components/BattleReports/MissionCard';
import { getCollection } from "astro:content";
import { SEO } from "astro-seo";
import BlogPostingJSONLD from '../../components/BlogPostingJSONLD.astro';
import PlayerSection from '../../components/BattleReports/PlayerSection.astro';
import TurnSection from '../../components/BattleReports/TurnSection.astro';
import { getFactionTheme, themeToStyle } from '../../utils/factionThemes';
import '@fontsource/cinzel/latin-400.css';
import '@fontsource/cinzel/latin-600.css';
import '@fontsource/cinzel/latin-700.css';
import '@fontsource/cinzel-decorative/latin-400.css';
import '@fontsource/cinzel-decorative/latin-700.css';
import '@fontsource/crimson-text/latin-400.css';
import '@fontsource/crimson-text/latin-400-italic.css';
import '@fontsource/crimson-text/latin-600.css';
import '@fontsource/crimson-text/latin-700.css';

export async function getStaticPaths() {    
    return (await getCollection('battle_report')).map((report) => {
        return {
            params: { slug: report.id},
            props: { entry: report },
        };
    });
}

const raw_cards = await getCollection('cards')
const indexed_cards = raw_cards.reduce((acc, card) => {
    acc[card.id] = card;
    return acc;
}, {});

const { entry } = Astro.props;

const attackerTheme = getFactionTheme(entry.data.game_data.attacker.faction);
const defenderTheme = getFactionTheme(entry.data.game_data.defender.faction);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageDescription = `${entry.data.description} Played on ${entry.data.date}.`;
const seoProps = {
    language: "en",
    pageTitle: entry.data.title,
    pageDescription,
    OG: {
        basic: {
            title: entry.data.title,
            type: "article",
            image: `${import.meta.env.SITE}og.png`,
        },
        article: {
            publishedTime: entry.data.pubDate.toISOString().substring(0, 10),
            author: [{ username: 'Krayorn' }],
            tags: entry.data.tags,
        },
        optional: { description: entry.data.description },
    },
};

let attackerScore = 0;
let defenderScore = 0;
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <SEO
        canonical={canonicalURL}
        description={seoProps.pageDescription}
        title={seoProps.pageTitle}
        twitter={{
            card: "summary_large_image",
            creator: "@Krayorn",
            title: seoProps.pageTitle,
            description: seoProps.pageDescription,
            image: seoProps.OG?.basic?.image,
        }}
        openGraph={seoProps.OG}
    />
    <BlogPostingJSONLD
        title={entry.data.title}
        description={entry.data.description}
        pubDate={entry.data.pubDate}
        tags={entry.data.tags}
    />
</head>
<body style={themeToStyle(attackerTheme)} class="bg-[var(--br-bg)] text-[var(--br-text)] font-body-serif min-h-screen">
    <nav class="bg-[var(--br-panel)] flex justify-center py-3 gap-6 text-sm font-gothic uppercase tracking-widest">
        <a href="/" class="text-[var(--br-accent)] hover:text-[var(--br-accent-light)] transition-colors">Home</a>
        <a href="/projects/" class="text-[var(--br-accent)] hover:text-[var(--br-accent-light)] transition-colors">Projects</a>
        <a href="/tags/" class="text-[var(--br-accent)] hover:text-[var(--br-accent-light)] transition-colors">Tags</a>
        <a href="/read-list/" class="text-[var(--br-accent)] hover:text-[var(--br-accent-light)] transition-colors">Read List</a>
    </nav>

    <div class="max-w-6xl mx-auto px-3 md:px-6 pt-8 pb-16">

        <!-- Title Header -->
        <header class="text-center mb-10">
            <div class="text-[var(--br-accent)] text-2xl tracking-[0.5em] mb-2">⚜ ✦ ⚜</div>
            <h1 class="font-gothic-decorative text-3xl md:text-4xl font-bold text-[var(--br-primary)] uppercase tracking-wider leading-tight">
                {entry.data.title}
            </h1>
            <div class="mt-3 flex items-center justify-center gap-4">
                <span class="h-px w-16 bg-[var(--br-accent)]"></span>
                <span class="text-sm font-gothic uppercase tracking-widest text-[var(--br-text-muted)]">{entry.data.date}</span>
                <span class="h-px w-16 bg-[var(--br-accent)]"></span>
            </div>
        </header>

        <!-- Description -->
        <div class="br-parchment-panel mb-10">
            <p class="text-lg leading-relaxed italic">{entry.data.description}</p>
        </div>

        <!-- Army Lists -->
        <div class="mb-10">
            <div class="flex items-center justify-center gap-4 mb-6">
                <span class="h-px flex-1 bg-[var(--br-accent)] opacity-40"></span>
                <h2 class="font-gothic text-xl font-bold uppercase tracking-widest text-[var(--br-primary)]">Army Lists</h2>
                <span class="h-px flex-1 bg-[var(--br-accent)] opacity-40"></span>
            </div>

            <div class="flex flex-col space-y-6 md:space-y-0 md:flex-row md:gap-6">
                <div class="md:w-1/2" style={themeToStyle(attackerTheme)}>
                    <PlayerSection name={entry.data.game_data.attacker.name} faction={entry.data.game_data.attacker.faction} detachment={entry.data.game_data.attacker.detachment} list={entry.data.game_data.attacker.list} />
                </div>
                <div class="md:w-1/2" style={themeToStyle(defenderTheme)}>
                    <PlayerSection name={entry.data.game_data.defender.name} faction={entry.data.game_data.defender.faction} detachment={entry.data.game_data.defender.detachment} list={entry.data.game_data.defender.list} />
                </div>
            </div>
        </div>

        <!-- Introduction & Primary Mission -->
        <div class="mb-10">
            <div class="br-parchment-panel mb-6">
                <p class="text-lg leading-relaxed">{entry.data.game_data.introduction}</p>
            </div>
            <div class="flex justify-center">
                <MissionCard mission={indexed_cards[entry.data.game_data.primary_mission].data} defender={false} />
            </div>
        </div>

        <!-- Rounds -->
        {entry.data.rounds.map((round, i) => {
            const currentAttackerScore = attackerScore 
            const currentDefenderScore = defenderScore 
            attackerScore = round.attacker.score.reduce((total, newScoreItem) => total + newScoreItem.value, attackerScore)
            defenderScore = round.defender.score.reduce((total, newScoreItem) => total + newScoreItem.value, defenderScore)
            return (
                <div class="my-10">
                    <!-- Round Header -->
                    <div class="flex items-center justify-center gap-3 mb-2">
                        <span class="h-px flex-1 bg-[var(--br-accent)] opacity-40"></span>
                        <div class="flex flex-col items-center">
                            <span class="text-[var(--br-accent)] text-sm">✦</span>
                            <h2 class="font-gothic-decorative text-2xl font-bold text-[var(--br-primary)] uppercase tracking-wider">
                                Round {i + 1}
                            </h2>
                            <span class="text-[var(--br-accent)] text-sm">✦</span>
                        </div>
                        <span class="h-px flex-1 bg-[var(--br-accent)] opacity-40"></span>
                    </div>

                    <!-- Score Bar -->
                    <div class="br-score-bar mb-6">
                        <span class="br-score-bar-faction font-gothic text-sm uppercase tracking-wider">{entry.data.game_data.attacker.faction}</span>
                        <div class="br-score-bar-scores flex items-center gap-3">
                            <span class="text-2xl font-gothic font-bold">{currentAttackerScore}</span>
                            <span class="text-[var(--br-accent)] text-lg">⚔</span>
                            <span class="text-2xl font-gothic font-bold">{currentDefenderScore}</span>
                        </div>
                        <span class="br-score-bar-faction font-gothic text-sm uppercase tracking-wider">{entry.data.game_data.defender.faction}</span>
                    </div>

                    <div style={themeToStyle(attackerTheme)}>
                        <TurnSection 
                            indexed_cards={indexed_cards}
                            round_number={i}
                            faction={entry.data.game_data.attacker.faction}
                            secondary_missions={round.attacker.secondary_missions}
                            content={round.attacker.content}
                            score={round.attacker.score}
                            defender={false}
                        />
                    </div>
                    
                    <div class="flex justify-center my-6">
                        <span class="text-[var(--br-accent)] tracking-[0.3em]">⚜ ⚜ ⚜</span>
                    </div>

                    <div style={themeToStyle(defenderTheme)}>
                        <TurnSection 
                            indexed_cards={indexed_cards}
                            round_number={i}
                            faction={entry.data.game_data.defender.faction}
                            secondary_missions={round.defender.secondary_missions}
                            content={round.defender.content}
                            score={round.defender.score}
                            defender={true}
                        />
                    </div>
                </div>
            )
        })}

        <!-- Final Score -->
        <div class="mt-12 mb-8">
            <div class="flex items-center justify-center gap-4 mb-6">
                <span class="h-px flex-1 bg-[var(--br-accent)] opacity-40"></span>
                <h2 class="font-gothic-decorative text-2xl font-bold uppercase tracking-widest text-[var(--br-primary)]">Final Score</h2>
                <span class="h-px flex-1 bg-[var(--br-accent)] opacity-40"></span>
            </div>

            <div class="br-final-score-card">
                <div class="flex flex-col items-center">
                    <span class="font-gothic text-sm uppercase tracking-widest text-[var(--br-accent-light)] mb-1">{entry.data.game_data.attacker.faction}</span>
                    <span class="font-gothic-decorative text-5xl font-bold text-[var(--br-text-on-dark)]">{attackerScore}</span>
                </div>

                <div class="flex flex-col items-center gap-1">
                    <span class="text-[var(--br-accent)] text-3xl">⚔</span>
                    <span class="font-gothic text-xs uppercase tracking-widest text-[var(--br-accent)]">Victory Points</span>
                </div>

                <div class="flex flex-col items-center">
                    <span class="font-gothic text-sm uppercase tracking-widest text-[var(--br-accent-light)] mb-1">{entry.data.game_data.defender.faction}</span>
                    <span class="font-gothic-decorative text-5xl font-bold text-[var(--br-text-on-dark)]">{defenderScore}</span>
                </div>
            </div>

            <div class="text-center mt-4 font-gothic text-sm uppercase tracking-widest text-[var(--br-text-muted)]">
                Tournament Score: {entry.data.game_data.attacker.faction} {10 + (Math.floor((Math.abs(attackerScore - defenderScore)) / 5) * (attackerScore > defenderScore ? 1 : -1) )} – {10 + (Math.floor((Math.abs(attackerScore - defenderScore)) / 5) * (defenderScore > attackerScore ? 1 : -1) )} {entry.data.game_data.defender.faction}
            </div>
        </div>

        <!-- Conclusion -->
        <div class="br-parchment-panel">
            <div class="text-[var(--br-accent)] text-center text-lg mb-3">⚜</div>
            <p class="text-lg leading-relaxed">{entry.data.game_data.conclusion}</p>
            <div class="text-[var(--br-accent)] text-center text-lg mt-3">⚜</div>
        </div>

        <div class="text-center text-[var(--br-accent)] text-2xl tracking-[0.5em] mt-10">⚜ ✦ ⚜</div>
    </div>
</body>
</html>

<style>
    .br-parchment-panel {
        background: linear-gradient(135deg, var(--br-bg-dark), var(--br-bg));
        border: 1px solid var(--br-accent);
        border-left: 4px solid var(--br-accent);
        padding: 1.5rem;
        position: relative;
    }

    .br-score-bar {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        background: var(--br-panel);
        color: var(--br-text-on-dark);
        padding: 0.75rem 1.5rem;
        border: 1px solid var(--br-accent);
    }

    .br-score-bar-faction:first-child {
        text-align: right;
    }

    .br-score-bar-faction:last-child {
        text-align: left;
    }

    .br-score-bar-scores {
        justify-self: center;
    }

    .br-final-score-card {
        display: flex;
        align-items: center;
        justify-content: space-around;
        background: var(--br-panel);
        color: var(--br-text-on-dark);
        padding: 2rem;
        border: 2px solid var(--br-accent);
        position: relative;
    }

    .br-final-score-card::before,
    .br-final-score-card::after {
        content: '✦';
        position: absolute;
        color: var(--br-accent);
        font-size: 0.75rem;
    }
    .br-final-score-card::before { top: 0.5rem; left: 0.75rem; }
    .br-final-score-card::after { bottom: 0.5rem; right: 0.75rem; }
</style>

