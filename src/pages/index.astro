---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPost from '../components/BlogPost.astro';

import { getPosts, getBattleReports } from '../utils/blog';

const pageTitle = "Krayorn's Blog";
const pageDescription = "A blog containing my thoughts and reflections on AI, Software, Board Games and whatever else finds it's way in my mind.";
const seoProps = {
  language: "en",
  pageTitle: pageTitle,
  pageDescription: pageDescription,
  OG: {
    basic: {
      title: pageTitle,
      type: "website",
      image: `${import.meta.env.SITE}og.png`,
    },
    optional: { description: pageDescription },
  },
}

const allPosts = await getPosts();
const allBattleReports = await getBattleReports();

const allContent = [...allPosts, ...allBattleReports];

---
<BaseLayout seoProps={seoProps}>
<script slot="head" type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Krayorn's Blog",
  "url": "https://www.krayorn.com",
  "description": pageDescription,
  "author": {
    "@type": "Person",
    "name": "Nathael Arki",
    "url": "https://www.krayorn.com"
  }
})} />
<section>
  Here's a list of all my blog posts! If you liked one of them, or did not, if it made you think, 
  if there's a typo that drove you crazy, if you want to ask some questions, or give me some feedback, or if you just want to chat, shoot me an email at <a href="mailto:me@krayorn.com" target="_blank">me@krayorn.com</a> 
  or send me a message on <a href={`https://www.twitter.com/krayorn`}>Twitter/X</a> ! I'd be thrilled to read it !
</section>
<ul>
    {allContent
      .sort((a, b) => b.data.pubDate > a.data.pubDate ? 1 : -1)
      .map(
        (post) => post.collection === 'blog' 
          ? <BlogPost tags={post.data.tags} description={post.data.description} url={`/posts/${post.data.perma != undefined ? post.data.perma : post.slug}/`} title={post.data.title} pubDate={post.data.pubDate} /> 
          : <BlogPost tags={post.data.tags} description={post.data.description} url={`/battle_reports/${post.id}/`} title={post.data.title} pubDate={post.data.pubDate} />
      )}
</ul>
</BaseLayout>


<style>
  ul {
    list-style-type: none;
    padding: 0;
  }
  a {
    color: theme('colors.green');
  }

</style>